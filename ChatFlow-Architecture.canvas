    },

    {
      "id": "nextjs-group",
      "x": -400,
      "y": -200,
      "width": 280,
      "height": 60,
      "type": "text",
      "text": "## ⚡ Next.js App\n`saas-ai-chatbot` on Vercel",
      "color": "2"
    },
    {
      "id": "nextjs-auth",
      "x": -400,
      "y": -120,
      "width": 280,
      "height": 50,
      "type": "text",
      "text": "🔐 Auth Pages\n`/auth/login` · `/auth/signup`\nSupabase Auth + Facebook OAuth",
      "color": "2"
    },
    {
      "id": "nextjs-dashboard",
      "x": -400,
      "y": -50,
      "width": 280,
      "height": 60,
      "type": "text",
      "text": "📊 Dashboard Pages\nOverview · Chatbots · Conversations\nLeads · Analytics · Settings",
      "color": "2"
    },
    {
      "id": "nextjs-api-webhook",
      "x": -400,
      "y": 30,
      "width": 280,
      "height": 50,
      "type": "text",
      "text": "🔗 API: Messenger Webhook\n`/api/messenger/webhook`\nReceives & forwards to n8n",
      "color": "2"
    },
    {
      "id": "nextjs-api-kb",
      "x": -400,
      "y": 100,
      "width": 280,
      "height": 60,
      "type": "text",
      "text": "📤 API: Knowledge Base\n`/api/knowledge-base`\nUpload · List · Delete files\nText extraction (PDF/DOCX/XLSX)",
      "color": "2"
    },
    {
      "id": "nextjs-api-chatbot",
      "x": -400,
      "y": 180,
      "width": 280,
      "height": 50,
      "type": "text",
      "text": "🤖 API: Chatbot CRUD\nServer actions for chatbot management",
      "color": "2"
    },
    {
      "id": "nextjs-api-settings",
      "x": -400,
      "y": 250,
      "width": 280,
      "height": 50,
      "type": "text",
      "text": "🎨 Theme System\n`next-themes` light/dark toggle\nCSS custom properties (oklch)",
      "color": "2"
    },

    {
      "id": "supabase-group",
      "x": 100,
      "y": -350,
      "width": 300,
      "height": 60,
      "type": "text",
      "text": "## 🗄️ Supabase\nBackend-as-a-Service",
      "color": "5"
    },
    {
      "id": "supabase-auth",
      "x": 100,
      "y": -270,
      "width": 300,
      "height": 50,
      "type": "text",
      "text": "🔑 Auth Service\nEmail/Password + Facebook OAuth\nJWT tokens · RLS enforcement",
      "color": "5"
    },
    {
      "id": "supabase-db",
      "x": 100,
      "y": -200,
      "width": 300,
      "height": 80,
      "type": "text",
      "text": "🐘 PostgreSQL Database\n`chatbots` — config per bot\n`conversations` — message threads\n`knowledge_base_files` — uploaded docs\n`leads` — captured contact info",
      "color": "5"
    },
    {
      "id": "supabase-storage",
      "x": 100,
      "y": -100,
      "width": 300,
      "height": 60,
      "type": "text",
      "text": "💾 Storage Bucket\n`knowledge-base` (private)\nMax 10MB · PDF/TXT/DOCX/XLSX\nRLS: users access own files only",
      "color": "5"
    },
    {
      "id": "supabase-rls",
      "x": 100,
      "y": -20,
      "width": 300,
      "height": 50,
      "type": "text",
      "text": "🛡️ Row Level Security\nTenant isolation via `user_id`\nAll tables + storage objects",
      "color": "5"
    },

    {
      "id": "n8n-group",
      "x": 500,
      "y": -50,
      "width": 300,
      "height": 60,
      "type": "text",
      "text": "## ⚙️ n8n Workflow Engine\nSelf-hosted automation",
      "color": "3"
    },
    {
      "id": "n8n-webhook",
      "x": 500,
      "y": 30,
      "width": 300,
      "height": 50,
      "type": "text",
      "text": "📥 Webhook Receiver\nReceives forwarded messages\nfrom Next.js webhook API",
      "color": "3"
    },
    {
      "id": "n8n-lookup",
      "x": 500,
      "y": 100,
      "width": 300,
      "height": 60,
      "type": "text",
      "text": "🔍 Dynamic Config Lookup\nFetch chatbot settings from Supabase\nSystem prompt · Model · Knowledge base",
      "color": "3"
    },
    {
      "id": "n8n-ai",
      "x": 500,
      "y": 180,
      "width": 300,
      "height": 60,
      "type": "text",
      "text": "🧠 AI Processing\nInject system prompt + KB context\nCall selected AI model\nParse & format response",
      "color": "3"
    },
    {
      "id": "n8n-reply",
      "x": 500,
      "y": 260,
      "width": 300,
      "height": 50,
      "type": "text",
      "text": "📤 Send Reply\nPOST to Messenger Send API\nUsing page access token",
      "color": "3"
    },
    {
      "id": "n8n-lead",
      "x": 500,
      "y": 330,
      "width": 300,
      "height": 50,
      "type": "text",
      "text": "📋 Lead Capture\nDetect intent → save to `leads`\nEmail notification to owner",
      "color": "3"
    },
    {
      "id": "n8n-handoff",
      "x": 500,
      "y": 400,
      "width": 300,
      "height": 50,
      "type": "text",
      "text": "🙋 Human Handoff\nEscalate to handoff_email\nNotify via notify_emails list",
      "color": "3"
    },

