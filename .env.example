# =============================================
# ChatFlow – Environment Variables
# =============================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.

# ---- Supabase (Database & Auth) ----
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---- OpenAI (AI Model) ----
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ---- Facebook Messenger ----
# MESSENGER_VERIFY_TOKEN: A secret string YOU create and use in two places:
#   1. Set it here as an env var
#   2. Enter it in the Facebook Developer Console → Messenger → Webhooks → Verify Token
# It proves to Facebook that your webhook URL belongs to you.
# Use any random strong string, e.g.: openssl rand -hex 20
MESSENGER_VERIFY_TOKEN=your-random-secret-verify-token

# ---- Facebook OAuth (for page selection) ----
# Get these from: https://developers.facebook.com → Your App → Settings → Basic
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ---- App URL (for production) ----
# Your deployed domain, e.g. https://chatflow.vercel.app
# Used to construct webhook URLs in the dashboard
NEXT_PUBLIC_APP_URL=https://your-domain.com
